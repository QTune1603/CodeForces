#include<bits/stdc++.h>
using namespace std;


int main(){
	int t; cin >> t;
	while(t--){
		int n; cin >> n;
		vector<int> p;
		int l = 1 , r = 3*n;
		while(l <= r) {
			if(r-l+1 >= 3) {
				p.push_back(l);
				p.push_back(r-1);
				p.push_back(r);
				l++;
				r-=2;
			}
		}
		for(int x : p) cout << x << " ";
		cout << endl;
	}
}
