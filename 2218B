#include<bits/stdc++.h>
using namespace std;


int main(){
	int t; cin >> t;
	while(t--){
		vector<int> p(7);
		for(int i = 0 ; i < 7 ; i++){
			cin >> p[i];
		}
		sort(p.begin(), p.end());
		int sum = 0;
		for(int i = 0 ; i < 6 ; i++) {
			sum += -p[i];
		}
		sum = sum + p[p.size()-1];
		cout << sum << endl;
	}
}
